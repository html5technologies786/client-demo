# ──────────────────────────────────────────────
#  Copy this file to .env before running:
#    cp .env.example .env
# ──────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=appdb
POSTGRES_USER=appuser
POSTGRES_PASSWORD=apppassword

# Express API — uses internal Docker hostname
DATABASE_URL=postgresql://appuser:apppassword@postgres-db:5432/appdb

# Next.js — uses internal Docker hostname
API_URL=http://express-api:5000
